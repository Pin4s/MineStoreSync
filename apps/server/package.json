{
  "name": "@repo/server",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format cjs --clean --out-dir dist",
    "start": "node dist/server.cjs",
    "lint": "eslint . --max-warnings=0",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "5.14.0",
    "@repo/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "pg": "^8.21.0",
    "prisma": "5.14.0",
    "rcon-client": "^4.2.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@fastify/jwt": "^10.1.0",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "eslint": "^8.57.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.0"
  }
}
